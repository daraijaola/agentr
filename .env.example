#  LLM  pick one for MVP
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=

#  Active provider (anthropic | openai | moonshot)
LLM_PROVIDER=moonshot
LLM_MODEL=kimi-k2

#  Telegram (one app for all users  register at my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

#  TON
TON_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=
TONAPI_KEY=

#  Database
DATABASE_URL=postgresql://agentr:agentr@localhost:5432/agentr
REDIS_URL=redis://localhost:6379

#  API
API_PORT=3001
API_SECRET=your-secret-here

#  Docker
DOCKER_SOCKET=/var/run/docker.sock
AGENT_IMAGE=agentr-agent:latest

# Sessions
SESSIONS_PATH=/root/agentr/sessions
